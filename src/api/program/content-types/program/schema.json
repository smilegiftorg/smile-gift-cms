{
  "kind": "collectionType",
  "collectionName": "programs",
  "info": {
    "singularName": "program",
    "pluralName": "programs",
    "displayName": "Program",
    "description": "Collection for charitable programs/events"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "programs"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "upcoming",
        "completed"
      ],
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "date": {
      "type": "date",
      "required": true,
      "displayName": "Ngày diễn ra",
      "description": "Định dạng ngày: dd/mm/yyyy",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "location": {
      "type": "string",
      "required": true,
      "displayName": "Địa điểm",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "text",
      "required": true,
      "displayName": "Mô tả ngắn",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "priority": {
      "type": "integer",
      "default": 2,
      "required": true,
      "max": 2,
      "min": 1,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "maxAttendees": {
      "type": "integer",
      "min": 0,
      "displayName": "Số lượng người tham gia tối đa",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "longDescription": {
      "type": "richtext",
      "required": true,
      "displayName": "Mô tả chi tiết",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "program.schedules",
        "program.results"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.seo"
    },
    "relatedPrograms": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::program.program"
    }
  }
}
