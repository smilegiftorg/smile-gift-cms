{
  "kind": "collectionType",
  "collectionName": "programs",
  "info": {
    "singularName": "program",
    "pluralName": "programs",
    "displayName": "Program",
    "description": "Collection for charitable programs/events"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "files", "videos"]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "programs"
    },
    "status": {
      "type": "enumeration",
      "enum": ["upcoming", "completed"],
      "required": true
    },
    "date": {
      "type": "date",
      "required": true,
      "displayName": "Ngày diễn ra",
      "description": "Định dạng ngày: dd/mm/yyyy"
    },
    "location": {
      "type": "string",
      "required": true,
      "displayName": "Địa điểm"
    },
    "description": {
      "type": "text",
      "required": true,
      "displayName": "Mô tả ngắn"
    }
  }
}
